runs/**/work/*
!runs/**/work/words-original.json
runs/**/*.mp4
runs/**/*.mov
runs/**/*.mkv
runs/**/*.wav
runs/**/*.aiff
runs/**/*.m4a
testdata/*.mp4
testdata/*.wav
testdata/*.aiff

__pycache__/
*.egg-info/
build/
dist/
.venv/
.DS_Store
testdata/stress/*.mp4
testdata/stress/*.wav
testdata/stress/*.aiff
